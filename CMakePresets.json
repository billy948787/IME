{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "toolset": "host=x64",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_GENERATOR_INSTANCE": "$env{ProgramFiles}/Microsoft Visual Studio/2022/Community"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "Windows x64  |  Debug",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebugDLL"
      }
    },
    {
      "name": "x64-release",
      "displayName": "Windows x64  |  Release",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    },
    {
      "name": "x64-relwithdebinfo",
      "displayName": "Windows x64  |  RelWithDebInfo",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    },
    {
      "name": "x86-release",
      "displayName": "Windows x86  |  Release（32-bit）",
      "inherits": "base",
      "architecture": {
        "value": "Win32",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-debug-build",
      "displayName": "建置  x64 Debug",
      "configurePreset": "x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "x64-release-build",
      "displayName": "建置  x64 Release",
      "configurePreset": "x64-release",
      "configuration": "Release"
    },
    {
      "name": "x64-relwithdebinfo-build",
      "displayName": "建置  x64 RelWithDebInfo",
      "configurePreset": "x64-relwithdebinfo",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "x86-release-build",
      "displayName": "建置  x86 Release",
      "configurePreset": "x86-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "x64-debug-test",
      "displayName": "測試  x64 Debug",
      "configurePreset": "x64-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "x64-release-test",
      "displayName": "測試  x64 Release",
      "configurePreset": "x64-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}